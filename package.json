{
  "name": "@poweredbygen/gen-sdk",
  "version": "0.5.0",
  "description": "TypeScript SDK for the GEN Auto Content Engine API",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/poweredbyGEN/autocontentengine-sdk.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "gen",
    "autocontentengine",
    "sdk",
    "ai",
    "content-generation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
